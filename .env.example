# Plex connection — required
PLEX_URL=http://192.168.1.x:32400
PLEX_TOKEN=
PLEX_LIBRARY_NAME=Music

# Music library path — must exactly match the path Plex reports for file_path
# (the tool writes .lrc files to the same directory as each audio file)
MUSIC_DIR=/mnt/media/Music

# Scan settings
SCAN_INTERVAL_MINUTES=30
PORT=8000

# Optional: Genius API key (for plain-text fallback lyrics)
# Get one free at https://genius.com/api-clients
GENIUS_API_KEY=
